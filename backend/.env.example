# Copy this file to backend/.env and fill in real values.
# backend/.env is git-ignored — never commit secrets.

# --- Supabase Postgres connection ---
# Get this from: Supabase Dashboard → Settings → Database → Connection string
# Use the "Session pooler" entry (port 5432). Format example:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- JWT auth ---
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- App ---
CORS_ORIGINS=http://localhost:8000

# --- Optional fallback for offline demo on the teacher's machine ---
# Set USE_SQLITE=1 to ignore DATABASE_URL and use a local SQLite file.
USE_SQLITE=0

# --- Lab 4: Supabase Storage (cover image upload) ----------------
# If SUPABASE_SERVICE_KEY is empty (or USE_SQLITE=1), the backend
# falls back to local backend/uploads/ and serves them at /uploads/.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=article-covers
